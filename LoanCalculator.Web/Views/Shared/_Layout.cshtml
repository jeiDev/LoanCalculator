<!DOCTYPE html>

<html class="light" lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Calculadora de prestamos</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-error": "#ffffff",
                        "on-background": "#191c1e",
                        "tertiary-container": "#a33500",
                        "on-tertiary": "#ffffff",
                        "on-tertiary-fixed-variant": "#812800",
                        "secondary-fixed-dim": "#b4c5fb",
                        "primary-fixed-dim": "#b2c5ff",
                        "secondary": "#4c5d8d",
                        "surface-container-low": "#f3f4f6",
                        "outline-variant": "#c3c6d6",
                        "tertiary": "#7b2600",
                        "secondary-fixed": "#dae2ff",
                        "secondary-container": "#b6c8fe",
                        "on-surface": "#191c1e",
                        "surface-tint": "#0c56d0",
                        "primary-container": "#0052cc",
                        "on-secondary-container": "#415382",
                        "on-error-container": "#93000a",
                        "error": "#ba1a1a",
                        "outline": "#737685",
                        "tertiary-fixed": "#ffdbcf",
                        "on-primary": "#ffffff",
                        "on-secondary-fixed": "#021945",
                        "on-primary-fixed-variant": "#0040a2",
                        "surface-bright": "#f8f9fb",
                        "tertiary-fixed-dim": "#ffb59b",
                        "on-primary-fixed": "#001848",
                        "on-secondary": "#ffffff",
                        "on-surface-variant": "#434654",
                        "background": "#f8f9fb",
                        "on-primary-container": "#c4d2ff",
                        "surface-dim": "#d9dadc",
                        "on-secondary-fixed-variant": "#344573",
                        "inverse-surface": "#2e3132",
                        "error-container": "#ffdad6",
                        "on-tertiary-fixed": "#380d00",
                        "surface-variant": "#e1e2e4",
                        "surface": "#f8f9fb",
                        "inverse-primary": "#b2c5ff",
                        "surface-container": "#edeef0",
                        "surface-container-highest": "#e1e2e4",
                        "on-tertiary-container": "#ffc6b2",
                        "inverse-on-surface": "#f0f1f3",
                        "primary-fixed": "#dae2ff",
                        "primary": "#003d9b",
                        "surface-container-high": "#e7e8ea",
                        "surface-container-lowest": "#ffffff"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.5rem",
                        "lg": "1rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
</head>

<body class="bg-background text-on-background min-h-screen flex flex-col selection:bg-primary-container selection:text-on-primary">
    @{
        var path = Context.Request.Path.Value?.ToLowerInvariant() ?? "/";
        var isLogs = path.StartsWith("/logs");
        var isHome = !isLogs;
    }

    <nav class="w-full border-none bg-[#f8f9fb] dark:bg-[#191c1e] z-50">
        <div class="flex justify-between items-center px-8 py-4 w-full max-w-7xl mx-auto">
            <div class="text-xl font-black text-[#0052CC] dark:text-[#4791ff] font-['Manrope'] tracking-tight text-center md:text-left">
                Calculadora de prestamos
            </div>
            
            <div class="hidden md:flex items-center gap-8 font-['Manrope'] font-bold tracking-tight">
                <a class="@(isHome ? "text-[#0052CC] dark:text-[#4791ff] font-bold border-b-2 border-[#0052CC] pb-1" : "text-[#44474e] dark:text-[#c4c6cf] hover:text-[#0052CC] hover:bg-[#f3f4f6] transition-colors duration-200")"
                    href="/">Inicio</a>
                <a class="@(isLogs ? "text-[#0052CC] dark:text-[#4791ff] font-bold border-b-2 border-[#0052CC] pb-1" : "text-[#44474e] dark:text-[#c4c6cf] hover:text-[#0052CC] hover:bg-[#f3f4f6] transition-colors duration-200")"
                    href="/Logs">Logs</a>
            </div>
        </div>
    </nav>
    <main role="main" class="flex-grow flex items-start md:items-center justify-center p-6 pt-24 md:pt-6 relative overflow-hidden">
        @RenderBody()
    </main>
    
    <footer class="hidden md:flex w-full border-t border-opacity-15 border-[#0052CC] bg-[#f3f4f6] dark:bg-[#191c1e]">
        <div
            class="flex flex-col md:flex-row justify-between items-center px-8 py-12 w-full max-w-7xl mx-auto font-['Inter'] text-sm tracking-tight">
            <div class="mb-6 md:mb-0">
                <span class="font-['Manrope'] font-bold text-[#44474e]">Calculadora de prestamos</span>
                <p class="text-[#44474e] dark:text-[#c4c6cf] mt-1 opacity-80">© 2026 Sistema de calculadora de prestamos. Todos los derechos reservados.</p>
            </div>
            <div></div>
        </div>
    </footer>
    
    <div
        class="md:hidden fixed bottom-0 left-0 right-0 glass-panel border-t border-outline-variant/10 px-6 py-3 flex justify-center gap-40 items-center z-50">
        <a class="flex flex-col items-center gap-1 @(isHome ? "text-[#0052CC]" : "text-on-surface-variant")" href="/">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' @(isHome ? 1 : 0);">home</span>
            <span class="text-[10px] @(isHome ? "font-bold" : "font-medium")">Inicio</span>
        </a>
        <a class="flex flex-col items-center gap-1 @(isLogs ? "text-[#0052CC]" : "text-on-surface-variant")" href="/Logs">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' @(isLogs ? 1 : 0);">analytics</span>
            <span class="text-[10px] @(isLogs ? "font-bold" : "font-medium")">Logs</span>
        </a>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
