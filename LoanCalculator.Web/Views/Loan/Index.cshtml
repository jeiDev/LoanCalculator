@model LoanCalculator.Web.Models.LoanViewModel
<div class="w-full max-w-2xl">
    <div class="relative group">
        <div
            class="absolute inset-0 bg-surface-container-high rounded-xl translate-x-3 translate-y-3 -z-10 transition-transform group-hover:translate-x-2 group-hover:translate-y-2 duration-500">
        </div>
        <div
            class="bg-surface-container-lowest p-8 md:p-12 rounded-xl shadow-[0_32px_64px_rgba(25,28,30,0.06)] border border-outline-variant/15">
            <header class="mb-10 text-center">
                <span
                    class="inline-block py-1 px-3 bg-secondary-container text-on-secondary-container text-xs font-bold tracking-widest uppercase rounded-full mb-4">Herramientas
                    financieras</span>
                <h1 class="text-4xl font-extrabold text-on-surface tracking-tight mb-2">Calculadora de préstamos</h1>
                <p class="text-on-surface-variant text-sm tracking-tight">Calcula las condiciones de tu préstamo personal
                    con precisión.</p>
            </header>
            <form class="space-y-8"  asp-action="Calculate" method="post">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="flex flex-col">
                        <label
                            class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 ml-1">Fecha
                            de nacimiento</label>
                        <div class="cursor-pointer relative" onclick="document.getElementById('BirthDate')?.showPicker ? document.getElementById('BirthDate').showPicker() : document.getElementById('BirthDate')?.focus()">
                            <input
                                class="cursor-pointer w-full bg-surface-container-low border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary-container focus:bg-surface-container-lowest transition-all appearance-none [&::-webkit-calendar-picker-indicator]:hidden [&::-webkit-calendar-picker-indicator]:appearance-none"
                                placeholder="AAAA-MM-DD" type="date" asp-for="BirthDate" />
                            <span
                                class="cursor-pointer  material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">calendar_today</span>
                        </div>
                    </div>
                    
                    <div class="flex flex-col">
                        <label
                            class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 ml-1">Monto
                            del préstamo</label>
                        <div class="relative">
                            <span
                                class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant font-medium">$</span>
                            <input
                                class="w-full bg-surface-container-low border-none rounded-lg pl-8 pr-4 py-3 text-on-surface focus:ring-2 focus:ring-primary-container focus:bg-surface-container-lowest transition-all"
                                placeholder="5,000" step="100" type="number" asp-for="Amount" />
                        </div>
                    </div>
                    
                    <div class="flex flex-col md:col-span-2">
                        <label
                            class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 ml-1">Plazo
                            del préstamo</label>
                        <div class="relative">
                            <select
                                asp-for="Months"  class="w-full bg-surface-container-low border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary-container focus:bg-surface-container-lowest transition-all appearance-none cursor-pointer">
                                @foreach (var term in Model.Terms)
                                {
                                    <option value="@term">@term meses</option>
                                }
                            </select>
                            <span
                                class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                        </div>
                    </div>
                </div>

                <button
                    class="w-full py-4 bg-gradient-to-br from-[#003d9b] to-[#0052cc] text-on-primary font-bold rounded-lg shadow-lg shadow-primary/10 hover:shadow-primary/20 transition-all active:scale-[0.98]"
                    type="submit">
                    Calcular préstamo
                </button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.AgeStatusMessage))
            {
                <div class="mt-8 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">
                    <p class="text-sm font-semibold">@Model.AgeStatusMessage</p>
                </div>
            }
            
            @if (Model.MonthlyPayment > 0){
                <div class="mt-12 pt-12 border-t border-outline-variant/15">
                    <h2 class="text-lg font-bold text-on-surface mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary"
                            style="font-variation-settings: 'FILL' 1;">insights</span>
                        Estimaciones del préstamo
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        
                        <div
                            class="bg-surface-container-low p-5 rounded-lg border border-transparent hover:border-outline-variant/30 transition-colors">
                            <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">
                                Edad actual</p>
                            <p class="text-2xl font-black text-on-surface font-['Manrope']">@Model.Age</p>
                        </div>
                        
                        <div
                            class="bg-surface-container-low p-5 rounded-lg border border-transparent hover:border-outline-variant/30 transition-colors">
                            <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">
                                Tasa de interés</p>
                            <p class="text-2xl font-black text-primary font-['Manrope']">@Model.Rate %<span
                                    class="text-sm font-bold">%</span></p>
                        </div>
                        
                        <div
                            class="bg-surface-container-low p-5 rounded-lg border border-transparent hover:border-outline-variant/30 transition-colors">
                            <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">
                                Pago mensual</p>
                            <p class="text-2xl font-black text-on-surface font-['Manrope']">$@Model.MonthlyPayment.ToString("N2", new System.Globalization.CultureInfo("es-ES"))</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>